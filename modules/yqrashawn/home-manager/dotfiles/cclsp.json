{
  "servers": [
    {
      "extensions": [
        "js",
        "ts",
        "jsx",
        "tsx"
      ],
      "command": [
        "npx",
        "--",
        "typescript-language-server",
        "--stdio"
      ],
      "rootDir": "."
    },
    {
      "extensions": [
        "clj",
        "cljs",
        "cljc",
        "edn"
      ],
      "command": [
        "clojure-lsp"
      ],
      "rootDir": "."
    }
  ]
}
